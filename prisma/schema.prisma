datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") 
}

generator client {
  provider = "prisma-client-js"
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   
  category    String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
}

model Budget {
  id        String   @id @default(cuid())
  month     Int      // 0-11
  year      Int
  total     Float    @default(0)
  categoryTargets Json? // Stores { food: 1500, groceries: 200 }
  updatedAt DateTime @updatedAt

  @@unique([month, year]) // One budget record per month
}
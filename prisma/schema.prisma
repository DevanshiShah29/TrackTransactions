datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") 
}

generator client {
  provider = "prisma-client-js"
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   
  category    String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
}